        "district": "Barmer",
        "state": "Rajasthan",
        "lat": 25.7454,
        "lon": 71.3964
      },
      "affected_area_sq_km": 175,
      "trajectory": {
        "direction": "SE",
        "speed_km_per_day": 120,
        "predicted_path": [
          { "date": "2024-07-15", "district": "Jodhpur", "state": "Rajasthan", "threat_level": "HIGH" },
          { "date": "2024-07-16", "district": "Ajmer", "state": "Rajasthan", "threat_level": "HIGH" },
          { "date": "2024-07-17", "district": "Kota", "state": "Rajasthan", "threat_level": "MEDIUM" },
          { "date": "2024-07-18", "district": "Aurangabad", "state": "Maharashtra", "threat_level": "MEDIUM" },
