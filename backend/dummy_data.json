        { "crop": "Maize", "damage_pct": 55, "advisory": "Standing green maize is highly attractive to locusts. Apply malathion ULV spray at recommended dose." },
        { "crop": "Soybean", "damage_pct": 30, "advisory": "Broad-leaf soybean is vulnerable. Coordinate with district authorities for aerial spraying." },
        { "crop": "Sugarcane", "damage_pct": 20, "advisory": "Sugarcane relatively resistant at mature stage, but young ratoon crop is at risk." }
      ],
      "control_operations": {
        "aerial_spraying": true,
